# Google Cloud Storage Configuration
# Copy this file to .env and fill in your values

# Base64-encoded service account JSON key
# To encode your service account key:
#   Linux/Mac: base64 -w 0 path/to/service-account-key.json
#   Windows: certutil -encode path/to/service-account-key.json encoded.txt
# Then copy the encoded string (single line, no line breaks)
GCP_SA_KEY=your_base64_encoded_service_account_key_here

# Default GCS bucket name (optional - can be specified in code)
GCS_BUCKET=your-bucket-name

# GCP Project ID (optional - will be extracted from service account if not provided)
GCP_PROJECT=your-project-id
